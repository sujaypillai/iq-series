      "scope": "[format('Microsoft.Search/searchServices/{0}', variables('names').search)]",
      "name": "[guid(resourceGroup().id, variables('names').search, parameters('userObjectId'), variables('roles').searchIndexDataContributor)]",
      "properties": {
        "principalId": "[parameters('userObjectId')]",
        "principalType": "User",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roles').searchIndexDataContributor)]"
