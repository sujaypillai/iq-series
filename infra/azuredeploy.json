        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roles').cognitiveServicesOpenAIUser)]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Search/searchServices', variables('names').search)]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, variables('names').search, variables('roles').cognitiveServicesUser)]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Search/searchServices', variables('names').search), '2023-11-01', 'full').identity.principalId]",
