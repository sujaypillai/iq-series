        "authType": "AAD",
        "target": "[format('https://{0}.search.windows.net', variables('names').search)]",
        "isSharedToAll": true,
        "metadata": {
          "ApiType": "Azure",
          "ResourceId": "[resourceId('Microsoft.Search/searchServices', variables('names').search)]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/projects', variables('names').aiServices, variables('names').project)]",
        "[resourceId('Microsoft.Search/searchServices', variables('names').search)]"
      ]
