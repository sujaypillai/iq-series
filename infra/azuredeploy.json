    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-10-01-preview",
      "name": "[format('{0}/{1}', variables('names').openAi, variables('names').embeddingDeployment)]",
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('embeddingModelName')]",
          "version": "[parameters('embeddingModelVersion')]"
        },
        "raiPolicyName": "Microsoft.Default"
      },
      "sku": {
        "name": "Standard",
        "capacity": "[parameters('embeddingModelCapacity')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('names').openAi)]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-10-01-preview",
      "name": "[format('{0}/{1}', variables('names').openAi, variables('names').chatDeployment)]",
      "properties": {
