          "name": "[parameters('chatModelName')]",
          "version": "[parameters('chatModelVersion')]"
        },
        "raiPolicyName": "Microsoft.Default"
      },
      "sku": {
        "name": "GlobalStandard",
        "capacity": "[parameters('chatModelCapacity')]"
