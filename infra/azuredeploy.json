    "chatModelCapacity": {
      "type": "int",
      "defaultValue": 30,
      "minValue": 1,
      "maxValue": 200,
      "metadata": {
        "description": "Chat model capacity (1K TPM per unit)"
      }
    }
  },
  "variables": {
