      "metadata": {
        "description": "Embedding model capacity (1K TPM per unit)"
      }
    },
    "chatModelName": {
      "type": "string",
      "defaultValue": "gpt-4o-mini",
      "metadata": {
        "description": "Chat model name"
      }
    },
    "chatModelVersion": {
      "type": "string",
      "defaultValue": "2024-07-18",
